# Supabase Environment Variables
# Get these from: Supabase Dashboard → Settings → API

# Project URL (e.g., https://abcdefghijk.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public Key (safe to use in frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# Service Role Key (⚠ NEVER expose in frontend! Only use in Edge Functions)
VITE_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# Email Service (for Edge Function)
RESEND_API_KEY=re_your_resend_api_key_here

# Event Configuration
VITE_EVENT_NAME=CODECRYPT - Intellect '26
VITE_EVENT_DATE=2026-02-15
VITE_VENUE=Main Auditorium
